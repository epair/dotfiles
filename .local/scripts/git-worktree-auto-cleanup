#!/usr/bin/env bash

# Auto-cleanup merged PR worktrees
# Checks if worktrees marked as PR_SUBMITTED have their remote branches deleted

# Function to find git root with .bare directory
find_git_worktree_root() {
    local current_dir="$PWD"
    
    # Check current directory and parent directories for .bare
    while [[ "$current_dir" != "/" ]]; do
        if [[ -d "$current_dir/.bare" ]]; then
            echo "$current_dir"
            return 0
        fi
        current_dir=$(dirname "$current_dir")
    done
    
    return 1
}

# Find the worktree root
WORKTREE_ROOT=$(find_git_worktree_root)

if [[ -z "$WORKTREE_ROOT" ]]; then
    exit 1
fi

# Get list of worktrees (exclude hidden directories and main)
get_worktrees() {
    cd "$WORKTREE_ROOT" || return 1
    find . -maxdepth 1 -type d ! -name "." ! -name ".*" ! -name "main" -exec basename {} \; | sort
}

# Function to get branch prefix from worktree
get_branch_prefix() {
    local worktree_name="$1"
    local worktree_path="$WORKTREE_ROOT/$worktree_name"
    
    # Get the current branch name
    local branch_name=$(cd "$worktree_path" 2>/dev/null && git branch --show-current 2>/dev/null)
    
    if [[ -z "$branch_name" ]]; then
        echo ""  # No prefix
        return
    fi
    
    # Extract prefix by removing worktree name from the end of branch name
    if [[ "$branch_name" == *"$worktree_name" ]]; then
        # Remove the worktree name from the end to get prefix
        local prefix="${branch_name%$worktree_name}"
        echo "$prefix"
    else
        echo ""  # No prefix
    fi
}

# Fetch latest remote info
cd "$WORKTREE_ROOT/.bare" || cd "$WORKTREE_ROOT" || exit 1
git fetch --prune origin 2>/dev/null

# Track if any worktrees were deleted
deleted_count=0
deleted_worktrees=""

# Check each worktree
worktrees=$(get_worktrees)

while IFS= read -r worktree; do
    if [[ -n "$worktree" ]]; then
        worktree_path="$WORKTREE_ROOT/$worktree"
        
        # Check if this worktree has been PR'd
        if [[ -f "$worktree_path/.env" ]]; then
            if grep -q "^PR_SUBMITTED=true" "$worktree_path/.env" 2>/dev/null; then
                # Get the branch name for this worktree
                branch_name=$(cd "$worktree_path" 2>/dev/null && git branch --show-current 2>/dev/null)
                
                if [[ -n "$branch_name" ]]; then
                    # Check if the remote branch still exists
                    if ! git show-ref --verify --quiet "refs/remotes/origin/$branch_name" 2>/dev/null; then
                        # Remote branch is gone - this PR was likely merged
                        echo "Auto-deleting merged worktree: $worktree (branch: $branch_name)"
                        
                        # Get branch prefix for deletion
                        branch_prefix=$(get_branch_prefix "$worktree")
                        
                        # Kill tmux session if it exists
                        if tmux has-session -t "$worktree" 2>/dev/null; then
                            tmux kill-session -t "$worktree"
                        fi
                        
                        # Delete the worktree
                        WORKTREE_PREFIX="$branch_prefix" worktree-manager remove "$worktree" 2>/dev/null
                        
                        ((deleted_count++))
                        deleted_worktrees="${deleted_worktrees}${worktree}, "
                    fi
                fi
            fi
        fi
    fi
done <<< "$worktrees"

# Show notification if any worktrees were deleted
if [[ $deleted_count -gt 0 ]]; then
    # Remove trailing comma and space
    deleted_worktrees="${deleted_worktrees%, }"
    tmux display-message -d 3000 "Auto-cleaned $deleted_count merged worktree(s): $deleted_worktrees"
fi